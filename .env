# Postgres Environment Variables
POSTGRES_USER=pguser
POSTGRES_PASSWORD=pgpass
POSTGRES_DB=postgres
POSTGRES_HOST=localhost
POSTGRES_CONTAINER_HOST=app_postgis_db
POSTGRES_PORT=5432

# MLFlow Environment Variables
MLFLOW_HOST=localhost
MLFLOW_CONTAINER_HOST=mlflow_app
MLFLOW_PORT=7002
MLFLOW_UI_PORT=7003
MLFLOW_URI=http://${MLFLOW_HOST}:${MLFLOW_UI_PORT}
MLFLOW_TRACKING_DB_URI=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_CONTAINER_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}?options=-csearch_path=mlflow
MLFLOW_ARTIFACT_ROOT=./infrastructure/mlflow/artifacts

# Spark Environment Variables
SPARK_MASTER_RPC_PORT=7077
SPARK_MASTER_UI_PORT=7086
SPARK_WORKER_1_UI_PORT=7087
SPARK_WORKER_2_UI_PORT=7088
SPARK_WORKER_3_UI_PORT=7089
SPARK_HISTORY_UI_PORT=18080
SPARK_EVENTLOG_DIR=/opt/spark-events
SPARK_CORES_MAX=4
SPARK_EXECUTOR_CORES=2
SPARK_EXECUTOR_MEMORY=1g
SPARK_DRIVER_MEMORY=2g

# Flask - Model Deployment API Environment Variables
FASTAPI_MODEL_DEPLOYMENT_PORT=8084
FASTAPI_MODEL_DEPLOYMENT_PORT_DOCKER=8085
FASTAPI_MODEL_DEPLOYMENT_HOST=0.0.0.0

# Flask - Model Training API Environment Variables
FASTAPI_MODEL_TRAINING_HOST=0.0.0.0
FASTAPI_MODEL_TRAINING_PORT=8002
FASTAPI_MODEL_TRAINING_PORT_DOCKER=8003

# Flask - Data Processing API Environment Variables
FASTAPI_DATA_PROCESSING_HOST=0.0.0.0
FASTAPI_DATA_PROCESSING_PORT_DOCKER=5556
FASTAPI_DATA_PROCESSING_PORT=5557

PROCESSED_OUTPUT_DIR=/app/processed_output
